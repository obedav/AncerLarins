APP_NAME=AncerLarins
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Lagos
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ancerlarins
DB_USERNAME=ancerlarins
DB_PASSWORD=

# Security — Generate with: php -r "echo base64_encode(random_bytes(32));"
# IMPORTANT: This must be a separate key from APP_KEY and should never be rotated once set.
BLIND_INDEX_KEY=

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000
SANCTUM_TOKEN_EXPIRATION=1440
SANCTUM_TOKEN_PREFIX=ancerlrs_

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=ancerlarins_

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# SMS Provider (termii or 80kobo)
SMS_PROVIDER=termii
SMS_FALLBACK=80kobo

# External Services — fill in with your credentials
TERMII_API_KEY=
TERMII_BASE_URL=https://v3.api.termii.com/api
TERMII_SENDER_ID=AncerLarins
TERMII_WEBHOOK_SECRET=

# 80kobo SMS (alternative provider)
EIGHTY_KOBO_EMAIL=
EIGHTY_KOBO_PASSWORD=
EIGHTY_KOBO_SENDER_NAME=AncerLarins

# Cloudflare Turnstile (bot protection for public forms)
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PAYMENT_URL=https://api.paystack.co

CLOUDINARY_URL=
CLOUDINARY_UPLOAD_PRESET=ancerlarins_properties

FCM_SERVER_KEY=
FCM_PROJECT_ID=

# WebAuthn (Passkey Authentication)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=AncerLarins

# Super Admin Seed Credentials
SUPER_ADMIN_FIRST_NAME=Admin
SUPER_ADMIN_LAST_NAME=User
SUPER_ADMIN_EMAIL=admin@ancerlarins.com
SUPER_ADMIN_PHONE=+2340000000000
SUPER_ADMIN_PASSWORD=

# Error Tracking (Sentry)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Mail (Gmail SMTP — use App Password, not your Gmail password)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@ancerlarins.com"
MAIL_FROM_NAME="${APP_NAME}"
